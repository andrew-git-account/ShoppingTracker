# Shopping Tracker - Environment Variables Template
# Copy this file to .env and fill in your actual values
# IMPORTANT: Never commit .env to git (it's in .gitignore)

# ============================================
# Anthropic API Configuration
# ============================================
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ============================================
# Flask Configuration
# ============================================
# Application entry point
FLASK_APP=app.main

# Environment: development or production
FLASK_ENV=development

# Secret key for session management (generate a random string)
# You can generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_secret_key_here_use_random_string

# ============================================
# Application Settings
# ============================================
# Folder where uploaded receipts are temporarily stored
UPLOAD_FOLDER=./uploads

# Folder where JSON database is stored
DATA_FOLDER=./data

# Maximum upload file size in bytes (5MB = 5242880 bytes)
MAX_UPLOAD_SIZE=5242880

# Allowed file extensions (comma-separated, no spaces)
ALLOWED_EXTENSIONS=jpg,jpeg,png

# ============================================
# LLM Configuration
# ============================================
# Claude model to use for receipt processing
# Options: claude-3-5-sonnet-20241022, claude-3-opus-20240229
LLM_MODEL=claude-3-5-sonnet-20241022

# Maximum tokens for LLM response
LLM_MAX_TOKENS=4096

# Temperature for LLM (0.0 = deterministic, 1.0 = creative)
# For receipt extraction, use lower temperature for consistency
LLM_TEMPERATURE=0.0
